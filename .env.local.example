# ============================================================================
# Copy this file to .env.local and fill in the keys you have.
# Only OPENAI_API_KEY is required — it powers voice, transcription, and acts as
# the automatic fallback for any provider whose key is missing.
# ============================================================================

# --- Provider API keys ---
OPENAI_API_KEY=sk-...
# Optional — add when you have them; until then those tiers fall back to OpenAI.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Model identifiers (no model names are hardcoded in the app) ---
GEMINI_MODEL=gemini-1.5-flash
GPT4O_MODEL=gpt-4o
CLAUDE_SONNET_MODEL=claude-sonnet-4-20250514
# GPT-5.5 does not exist yet — placeholder maps to gpt-4o until it does.
GPT55_MODEL=gpt-4o
# Used whenever a provider key is absent.
OPENAI_FALLBACK_MODEL=gpt-4o

# --- Voice (OpenAI) ---
# OPENAI_TTS_VOICE=onyx
